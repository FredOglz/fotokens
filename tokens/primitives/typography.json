{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans":  { "$value": "Inter, system-ui, -apple-system, sans-serif" },
      "serif": { "$value": "Georgia, 'Times New Roman', serif" },
      "mono":  { "$value": "'JetBrains Mono', ui-monospace, 'SF Mono', monospace" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": "400" },
      "medium":   { "$value": "500" },
      "semibold": { "$value": "600" },
      "bold":     { "$value": "700" }
    },
    "lineHeight": {
      "$type": "number",
      "tight":   { "$value": "1.2" },
      "normal":  { "$value": "1.5" },
      "relaxed": { "$value": "1.75" }
    }
  }
}

{
  "color": {
    "select": {
      "default": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.border.default}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        },
        "icon": {
          "$value": "{color.text.muted}"
        }
      },
      "hover": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.border.strong}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        },
        "icon": {
          "$value": "{color.text.muted}"
        }
      },
      "focus": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.role.primary.main}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        },
        "icon": {
          "$value": "{color.text.muted}"
        }
      },
      "disabled": {
        "background": {
          "$value": "{color.surface.disabled}"
        },
        "text": {
          "$value": "{color.text.disabled}"
        },
        "border": {
          "$value": "{color.border.disabled}"
        },
        "placeholder": {
          "$value": "{color.text.disabled}"
        },
        "icon": {
          "$value": "{color.text.disabled}"
        }
      },
      "error": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.role.danger.main}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        },
        "icon": {
          "$value": "{color.text.muted}"
        }
      }
    },
    "$type": "color"
  },
  "size": {
    "select": {
      "sm": {
        "height": {
          "$value": "{controlHeight.sm}"
        },
        "icon": {
          "$value": "{glyphSize.sm}"
        }
      },
      "md": {
        "height": {
          "$value": "{controlHeight.md}"
        },
        "icon": {
          "$value": "{glyphSize.md}"
        }
      },
      "lg": {
        "height": {
          "$value": "{controlHeight.lg}"
        },
        "icon": {
          "$value": "{glyphSize.lg}"
        }
      }
    },
    "$type": "dimension"
  },
  "space": {
    "select": {
      "sm": {
        "paddingX": {
          "$value": "{space.sm}"
        },
        "paddingY": {
          "$value": "{space.xs}"
        },
        "gap": {
          "$value": "{space.xs}"
        }
      },
      "md": {
        "paddingX": {
          "$value": "{space.sm}"
        },
        "paddingY": {
          "$value": "{space.sm}"
        },
        "gap": {
          "$value": "{space.xs}"
        }
      },
      "lg": {
        "paddingX": {
          "$value": "{space.md}"
        },
        "paddingY": {
          "$value": "{space.sm}"
        },
        "gap": {
          "$value": "{space.xs}"
        }
      }
    },
    "$type": "dimension"
  },
  "fontSize": {
    "select": {
      "sm": {
        "$value": "{fontSize.small}"
      },
      "md": {
        "$value": "{fontSize.body}"
      },
      "lg": {
        "$value": "{fontSize.lead}"
      }
    },
    "$type": "dimension"
  },
  "radius": {
    "select": {
      "sm": {
        "$value": "{radius.sm}"
      },
      "md": {
        "$value": "{radius.sm}"
      },
      "lg": {
        "$value": "{radius.md}"
      }
    },
    "$type": "dimension"
  },
  "borderWidth": {
    "select": {
      "sm": {
        "$value": "{borderWidth.default}"
      },
      "md": {
        "$value": "{borderWidth.default}"
      },
      "lg": {
        "$value": "{borderWidth.default}"
      }
    },
    "$type": "dimension"
  }
}

{
  "color": {
    "textarea": {
      "default": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.border.default}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        }
      },
      "hover": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.border.strong}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        }
      },
      "focus": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.role.primary.main}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        }
      },
      "disabled": {
        "background": {
          "$value": "{color.surface.disabled}"
        },
        "text": {
          "$value": "{color.text.disabled}"
        },
        "border": {
          "$value": "{color.border.disabled}"
        },
        "placeholder": {
          "$value": "{color.text.disabled}"
        }
      },
      "error": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "text": {
          "$value": "{color.text.body}"
        },
        "border": {
          "$value": "{color.role.danger.main}"
        },
        "placeholder": {
          "$value": "{color.text.muted}"
        }
      }
    },
    "$type": "color"
  },
  "space": {
    "textarea": {
      "paddingX": {
        "$value": "{space.sm}"
      },
      "paddingY": {
        "$value": "{space.sm}"
      }
    },
    "$type": "dimension"
  },
  "fontSize": {
    "textarea": {
      "$value": "{fontSize.body}"
    },
    "$type": "dimension"
  },
  "radius": {
    "textarea": {
      "$value": "{radius.sm}"
    },
    "$type": "dimension"
  },
  "borderWidth": {
    "textarea": {
      "$value": "{borderWidth.default}"
    },
    "$type": "dimension"
  }
}

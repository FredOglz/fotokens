{
  "color": {
    "tooltip": {
      "default": {
        "background": {
          "$value": "{color.surface.inverse}"
        },
        "text": {
          "$value": "{color.text.inverse}"
        }
      }
    },
    "$type": "color"
  },
  "space": {
    "tooltip": {
      "paddingX": {
        "$value": "{space.sm}"
      },
      "paddingY": {
        "$value": "{space.xs}"
      }
    },
    "$type": "dimension"
  },
  "fontSize": {
    "tooltip": {
      "$value": "{fontSize.small}"
    },
    "$type": "dimension"
  },
  "radius": {
    "tooltip": {
      "$value": "{radius.sm}"
    },
    "$type": "dimension"
  },
  "typography": {
    "tooltip": {
      "family": {
        "$type": "fontFamily",
        "$value": "{typography.small.family}"
      },
      "weight": {
        "$type": "fontWeight",
        "$value": "{typography.small.weight}"
      },
      "lineHeight": {
        "$type": "number",
        "$value": "{typography.small.lineHeight}"
      },
      "letterSpacing": {
        "$type": "dimension",
        "$value": "{typography.small.letterSpacing}"
      },
      "textCase": {
        "$value": "{typography.small.textCase}"
      }
    }
  }
}

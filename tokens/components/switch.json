  "size": {
    "switch": {
      "sm": {
        "trackWidth": {
          "$value": "{size.control.lg}"
        },
        "trackHeight": {
          "$value": "{glyphSize.md}"
        },
        "thumb": {
          "$value": "{glyphSize.sm}"
        }
      },
      "md": {
        "trackWidth": {
          "$value": "{size.control.xl}"
        },
        "trackHeight": {
          "$value": "{glyphSize.lg}"
        },
        "thumb": {
          "$value": "{glyphSize.md}"
        }
      },
      "lg": {
        "trackWidth": {
          "$value": "{size.spacing.11}"
        },
        "trackHeight": {
          "$value": "{size.control.sm}"
        },
        "thumb": {
          "$value": "{glyphSize.md}"
        }

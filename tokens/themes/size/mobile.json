{
  "space": {
    "$type": "dimension",
    "xs": {
      "$value": "{size.spacing.1}"
    },
    "sm": {
      "$value": "{size.spacing.2}"
    },
    "md": {
      "$value": "{size.spacing.4}"
    },
    "lg": {
      "$value": "{size.spacing.5}"
    },
    "xl": {
      "$value": "{size.spacing.7}"
    }
  },
  "radius": {
    "$type": "dimension",
    "sm": {
      "$value": "{size.radius.sm}"
    },
    "md": {
      "$value": "{size.radius.md}"
    },
    "lg": {
      "$value": "{size.radius.md}"
    },
    "full": {
      "$value": "{size.radius.full}"
    }
  },
  "borderWidth": {
    "$type": "dimension",
    "default": {
      "$value": "{size.border.sm}"
    },
    "strong": {
      "$value": "{size.border.md}"
    },
    "focus": {
      "$value": "{size.border.md}"
    }
  },
  "fontSize": {
    "$type": "dimension",
    "$description": "Seul le HAUT de l'échelle se comprime. Un titre à 48px sur un écran de 375px dévore la largeur et se casse en quatre lignes : il descend à 32px. Le texte de lecture, lui, ne descend JAMAIS sous sa valeur desktop — un téléphone se tient à bout de bras, le corps a besoin d'au moins autant de taille, pas de moins. C'est la même logique que `controlHeight`, qui GRANDIT sur mobile.",
    "caption": {
      "$value": "{size.font.xs}"
    },
    "small": {
      "$value": "{size.font.sm}"
    },
    "body": {
      "$value": "{size.font.md}"
    },
    "lead": {
      "$value": "{size.font.lg}"
    },
    "h3": {
      "$value": "{size.font.xl}"
    },
    "h2": {
      "$value": "{size.font.2xl}"
    },
    "h1": {
      "$value": "{size.font.3xl}"
    }
  },
  "controlHeight": {
    "$type": "dimension",
    "$description": "Hauteur des contrôles interactifs. Sur mobile, elles GRANDISSENT : une cible tactile doit faire au moins 44px (WCAG 2.5.5). C'est la seule famille de tailles qui augmente au lieu de diminuer.",
    "xs": {
      "$value": "{size.control.sm}"
    },
    "sm": {
      "$value": "{size.control.md}"
    },
    "md": {
      "$value": "{size.control.xl}"
    },
    "lg": {
      "$value": "{size.control.xl}"
    }
  },
  "glyphSize": {
    "$type": "dimension",
    "xs": {
      "$value": "{size.glyph.sm}"
    },
    "sm": {
      "$value": "{size.glyph.md}"
    },
    "md": {
      "$value": "{size.glyph.md}"
    },
    "lg": {
      "$value": "{size.glyph.lg}"
    }
  }
}

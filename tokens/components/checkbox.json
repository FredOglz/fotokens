{
  "color": {
    "checkbox": {
      "unchecked": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.border.strong}"
        },
        "mark": {
          "$value": "{color.surface.transparent}"
        }
      },
      "uncheckedHover": {
        "background": {
          "$value": "{color.role.primary.tint}"
        },
        "border": {
          "$value": "{color.role.primary.main}"
        },
        "mark": {
          "$value": "{color.surface.transparent}"
        }
      },
      "checked": {
        "background": {
          "$value": "{color.role.primary.main}"
        },
        "border": {
          "$value": "{color.role.primary.main}"
        },
        "mark": {
          "$value": "{color.role.primary.on}"
        }
      },
      "checkedHover": {
        "background": {
          "$value": "{color.role.primary.hover}"
        },
        "border": {
          "$value": "{color.role.primary.hover}"
        },
        "mark": {
          "$value": "{color.role.primary.on}"
        }
      },
      "indeterminate": {
        "background": {
          "$value": "{color.role.primary.main}"
        },
        "border": {
          "$value": "{color.role.primary.main}"
        },
        "mark": {
          "$value": "{color.role.primary.on}"
        }
      },
      "error": {
        "background": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.role.danger.main}"
        },
        "mark": {
          "$value": "{color.surface.transparent}"
        }
      },
      "errorHover": {
        "background": {
          "$value": "{color.role.danger.tint}"
        },
        "border": {
          "$value": "{color.role.danger.main}"
        },
        "mark": {
          "$value": "{color.surface.transparent}"
        }
      },
      "disabled": {
        "background": {
          "$value": "{color.surface.disabled}"
        },
        "border": {
          "$value": "{color.border.disabled}"
        },
        "mark": {
          "$value": "{color.surface.transparent}"
        }
      },
      "disabledChecked": {
        "background": {
          "$value": "{color.surface.disabled}"
        },
        "border": {
          "$value": "{color.border.disabled}"
        },
        "mark": {
          "$value": "{color.text.disabled}"
        }
      }
    },
    "$type": "color"
  },
  "size": {
    "checkbox": {
      "sm": {
        "box": {
          "$value": "{glyphSize.sm}"
        },
        "icon": {
          "$value": "{glyphSize.xs}"
        }
      },
      "md": {
        "box": {
          "$value": "{glyphSize.md}"
        },
        "icon": {
          "$value": "{glyphSize.sm}"
        }
      },
      "lg": {
        "box": {
          "$value": "{glyphSize.lg}"
        },
        "icon": {
          "$value": "{glyphSize.md}"
        }
      }
    },
    "$type": "dimension"
  },
  "radius": {
    "checkbox": {
      "sm": {
        "$value": "{radius.sm}"
      },
      "md": {
        "$value": "{radius.sm}"
      },
      "lg": {
        "$value": "{radius.sm}"
      }
    },
    "$type": "dimension"
  },
  "borderWidth": {
    "checkbox": {
      "sm": {
        "$value": "{borderWidth.strong}"
      },
      "md": {
        "$value": "{borderWidth.strong}"
      },
      "lg": {
        "$value": "{borderWidth.strong}"
      }
    },
    "$type": "dimension"
  }
}

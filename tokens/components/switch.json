{
  "color": {
    "switch": {
      "off": {
        "track": {
          "$value": "{color.border.strong}"
        },
        "thumb": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.border.transparent}"
        }
      },
      "offHover": {
        "track": {
          "$value": "{color.role.neutral.main}"
        },
        "thumb": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.border.transparent}"
        }
      },
      "on": {
        "track": {
          "$value": "{color.role.primary.main}"
        },
        "thumb": {
          "$value": "{color.role.primary.on}"
        },
        "border": {
          "$value": "{color.border.transparent}"
        }
      },
      "onHover": {
        "track": {
          "$value": "{color.role.primary.hover}"
        },
        "thumb": {
          "$value": "{color.role.primary.on}"
        },
        "border": {
          "$value": "{color.border.transparent}"
        }
      },
      "error": {
        "track": {
          "$value": "{color.border.strong}"
        },
        "thumb": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.role.danger.main}"
        }
      },
      "errorHover": {
        "track": {
          "$value": "{color.role.neutral.main}"
        },
        "thumb": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.role.danger.main}"
        }
      },
      "disabledOff": {
        "track": {
          "$value": "{color.surface.disabled}"
        },
        "thumb": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.border.transparent}"
        }
      },
      "disabledOn": {
        "track": {
          "$value": "{color.surface.disabled}"
        },
        "thumb": {
          "$value": "{color.surface.base}"
        },
        "border": {
          "$value": "{color.border.transparent}"
        }
      }
    },
    "$type": "color"
  },
  "size": {
    "switch": {
      "sm": {
        "trackWidth": {
          "$value": "{trackWidth.sm}"
        },
        "trackHeight": {
          "$value": "{trackHeight.sm}"
        },
        "thumb": {
          "$value": "{glyphSize.sm}"
        }
      },
      "md": {
        "trackWidth": {
          "$value": "{trackWidth.md}"
        },
        "trackHeight": {
          "$value": "{trackHeight.md}"
        },
        "thumb": {
          "$value": "{glyphSize.md}"
        }
      },
      "lg": {
        "trackWidth": {
          "$value": "{trackWidth.lg}"
        },
        "trackHeight": {
          "$value": "{trackHeight.lg}"
        },
        "thumb": {
          "$value": "{glyphSize.md}"
        }
      }
    },
    "$type": "dimension"
  },
  "radius": {
    "switch": {
      "sm": {
        "$value": "{radius.full}"
      },
      "md": {
        "$value": "{radius.full}"
      },
      "lg": {
        "$value": "{radius.full}"
      }
    },
    "$type": "dimension"
  },
  "borderWidth": {
    "switch": {
      "sm": {
        "$value": "{borderWidth.strong}"
      },
      "md": {
        "$value": "{borderWidth.strong}"
      },
      "lg": {
        "$value": "{borderWidth.strong}"
      }
    },
    "$type": "dimension"
  }
}

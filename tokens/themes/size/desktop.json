{
  "space": {
    "$type": "dimension",
    "xs": {
      "$value": "{size.spacing.2}"
    },
    "sm": {
      "$value": "{size.spacing.3}"
    },
    "md": {
      "$value": "{size.spacing.5}"
    },
    "lg": {
      "$value": "{size.spacing.7}"
    },
    "xl": {
      "$value": "{size.spacing.8}"
    }
  },
  "radius": {
    "$type": "dimension",
    "sm": {
      "$value": "{size.radius.sm}"
    },
    "md": {
      "$value": "{size.radius.md}"
    },
    "lg": {
      "$value": "{size.radius.lg}"
    },
    "full": {
      "$value": "{size.radius.full}"
    }
  },
  "borderWidth": {
    "$type": "dimension",
    "default": {
      "$value": "{size.border.sm}"
    },
    "strong": {
      "$value": "{size.border.md}"
    },
    "focus": {
      "$value": "{size.border.md}"
    }
  },
  "fontSize": {
    "$type": "dimension",
    "$description": "Les tailles vivent ICI, et non dans le thème typo, parce qu'elles sont la SEULE dimension de la typo qui change entre desktop et mobile. Un rôle typo pointe sur ces tokens : il hérite donc de la bascule sans rien savoir d'elle.",
    "caption": {
      "$value": "{size.font.xs}"
    },
    "small": {
      "$value": "{size.font.sm}"
    },
    "body": {
      "$value": "{size.font.md}"
    },
    "lead": {
      "$value": "{size.font.xl}"
    },
    "h3": {
      "$value": "{size.font.2xl}"
    },
    "h2": {
      "$value": "{size.font.3xl}"
    },
    "h1": {
      "$value": "{size.font.5xl}"
    }
  },
  "controlHeight": {
    "$type": "dimension",
    "$description": "Hauteur des contrôles interactifs. Sur mobile, elles GRANDISSENT : une cible tactile doit faire au moins 44px (WCAG 2.5.5). C'est la seule famille de tailles qui augmente au lieu de diminuer.",
    "xs": {
      "$value": "{size.control.xs}"
    },
    "sm": {
      "$value": "{size.control.sm}"
    },
    "md": {
      "$value": "{size.control.md}"
    },
    "lg": {
      "$value": "{size.control.lg}"
    }
  },
  "glyphSize": {
    "$type": "dimension",
    "xs": {
      "$value": "{size.glyph.xs}"
    },
    "sm": {
      "$value": "{size.glyph.sm}"
    },
    "md": {
      "$value": "{size.glyph.md}"
    },
    "lg": {
      "$value": "{size.glyph.lg}"
    }
  }
}
